{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "fix",
  "semanticCommitScope": "deps",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track the bjw-s app-template Helm chart version pinned in docs/kubernetes.md",
      "managerFilePatterns": ["/^docs/kubernetes\\.md$/"],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/bjw-s-labs/helm/app-template",
      "matchStrings": [
        "app-template --version (?<currentValue>\\d+\\.\\d+\\.\\d+)",
        "app-template\\s+ref:\\s+tag: (?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Track the ws4kp image tag pinned in the docs/kubernetes.md example so it follows releases",
      "managerFilePatterns": ["/^docs/kubernetes\\.md$/"],
      "datasourceTemplate": "docker",
      "depNameTemplate": "ghcr.io/jacaudi/ws4kp",
      "versioningTemplate": "semver",
      "matchStrings": [
        "repository: ghcr\\.io/jacaudi/ws4kp\\s+tag: (?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ]
    }
  ]
}
