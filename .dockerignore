# Dependencies + build output are (re)generated inside the image
node_modules
dist/

# VCS, CI, editor, OS, and agent-session scratch — not needed in the image
.git/
.github/
.vscode/
.superpowers/
.DS_Store

# The build's own Dockerfile doesn't need to be copied into the image
Dockerfile

# NOTE: do NOT ignore .archive/ (the archived static Dockerfile COPYs
# .archive/static/{nginx.conf,static-env-handler.sh}) or datagenerators/
# (the server reads datagenerators/output/*.json at startup).
